# Forge gateway configuration. Copy to .env and fill in.

# Master API key clients must send as: Authorization: Bearer <key>
FORGE_MASTER_KEY=change-me

# Upstream provider keys (set the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local Ollama (no key needed)
FORGE_OLLAMA_BASE_URL=http://localhost:11434

# Infrastructure
FORGE_DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
FORGE_REDIS_URL=redis://localhost:6379/0

# PII scrubbing (ADR-0007) — on by default; disabling is recorded in the audit
# trail. Allow-list domain terms the NER model false-positives on (JSON list).
FORGE_PII_SCRUBBING_ENABLED=true
# FORGE_PII_ALLOW_LIST=["Metformin","Lisinopril"]
